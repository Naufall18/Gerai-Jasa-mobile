<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ system splash: brand-green background + Gerai Jasa mark
         (replaces the default Flutter launcher icon shown during cold start). -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">@color/gj_splash</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/gj_splash_logo</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
